# Text defaults
* text=auto
# Windows-facing scripts
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf
*.bas text eol=crlf
# Docs and structured config
*.md text eol=lf
*.json text eol=lf
*.csv text eol=crlf
*.xml text eol=lf
*.mjs text eol=lf
*.js text eol=lf
*.py text eol=lf
*.cs text eol=lf
*.csproj text eol=lf
# Office/media/binary artifacts
*.ppt binary
*.pptx binary
*.pptm binary
*.potx binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.mp4 binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
*.bin binary
*.param binary
# Large sample/tool payloads must use Git LFS for GitHub compatibility.
PPTX/*.pptx filter=lfs diff=lfs merge=lfs -text
tools/vendor/pandoc/*.zip filter=lfs diff=lfs merge=lfs -text
tools/vendor/pandoc/**/pandoc.exe filter=lfs diff=lfs merge=lfs -text
tools/vendor/realesrgan-ncnn-vulkan-20220424/*.exe filter=lfs diff=lfs merge=lfs -text
tools/vendor/realesrgan-ncnn-vulkan-20220424/*.dll filter=lfs diff=lfs merge=lfs -text
tools/vendor/realesrgan-ncnn-vulkan-20220424/*.jpg filter=lfs diff=lfs merge=lfs -text
tools/vendor/realesrgan-ncnn-vulkan-20220424/*.mp4 filter=lfs diff=lfs merge=lfs -text
tools/vendor/realesrgan-ncnn-vulkan-20220424/models/*.bin filter=lfs diff=lfs merge=lfs -text
